# Rust
src-tauri/target
src-tauri/gen

# ts-rs generated bindings: keep the frontend mirror (src/ipc/bindings/) in
# version control so fresh clones build without a separate generation step;
# src-tauri/bindings/ is the raw output and stays ignored.
src-tauri/bindings/

# TS project-reference build artifacts
*.tsbuildinfo
dist-tsc-node

# Playwright
test-results/
playwright-report/
.playwright/

# Tauri icon generator emits Windows-Store / iOS / Android assets we don't
# use on a macOS-only build. Regenerate any time with
# `npm run tauri icon src-tauri/icons/source.png`.
src-tauri/icons/64x64.png
src-tauri/icons/Square*Logo.png
src-tauri/icons/StoreLogo.png
src-tauri/icons/ios/
src-tauri/icons/android/
